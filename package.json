{
    "name": "ulju-ai-kiosk-electron",
    "productName": "울주 AI 키오스크",
    "version": "1.0.1",
    "description": "Electron wrapper for the Ulju AI kiosk deployed web app.",
    "main": "main.js",
    "build": {
        "appId": "com.my.kiosk",
        "mac": {
            "target": "dmg",
            "category": "public.app-category.utilities",
            "icon": "build/icon.icns",
            "artifactName": "UljuKiosk-${version}-mac.${ext}",
            "hardenedRuntime": true,
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.inherit.plist",
            "extendInfo": {
                "NSCameraUsageDescription": "QR 코드 인식과 얼굴 확인을 위해 카메라 접근이 필요합니다."
            }
        },
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "uxroom001",
                "repo": "ulju-ai-kiosk-electron"
            }
        ],
        "icon": "build/icon.ico",
        "artifactName": "UljuKioskSetup.exe"
    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "electron .",
        "dist": "electron-builder"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "electron-updater": "^6.8.3"
    }
}
